{
	"name": "@half-pi/half-pi",
	"version": "0.1.0",
	"description": "half-pi: half cloud, half local — a self-improving agent framework forked from pi",
	"type": "module",
	"piConfig": {
		"configDir": ".half-pi"
	},
	"bin": {
		"half-pi": "dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@earendil-works/pi-agent-core": "*",
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-tui": "*",
		"cross-spawn": "^7.0.6",
		"typebox": "^1.1.24"
	},
	"devDependencies": {
		"@types/cross-spawn": "^6.0.6",
		"@types/node": "^24.3.0",
		"shx": "^0.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	},
	"keywords": [
		"agent",
		"ai",
		"llm",
		"cli",
		"half-pi",
		"self-improving"
	],
	"author": "社亦园",
	"license": "MIT",
	"engines": {
		"node": ">=22.19.0"
	}
}
