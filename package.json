{
	"name": "half-pi-monorepo",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"clean": "npm run clean --workspaces --if-present",
		"build": "./node_modules/.bin/tsc -p packages/tui/tsconfig.build.json && ./node_modules/.bin/tsc -p packages/ai/tsconfig.build.json && ./node_modules/.bin/tsc -p packages/agent/tsconfig.build.json && ./node_modules/.bin/tsc -p packages/half-pi/tsconfig.build.json",
		"check": "true",
		"test": "npm run test --workspaces --if-present"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
